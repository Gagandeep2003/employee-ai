# Copy to .env and fill in. Never commit the real .env file.

# --- Runtime ---
ENV=development                   # development | production -- production enforces strict validation below

# --- Database ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=ai_employee

# --- Auth ---
JWT_SECRET=                       # required. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_EMAIL=                      # optional but recommended -- the ONLY way an account becomes admin
ADMIN_PASSWORD=                   # required if ADMIN_EMAIL is set; 10+ characters in production

# --- CORS ---
# Comma-separated list of exact origins allowed to call this API with credentials.
# Required (no wildcard) in production.
CORS_ORIGINS=http://localhost:3000

# --- Gemini (LLM) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Object storage (S3-compatible) ---
# Leave all blank to fall back to local disk (fine for a single-instance dev/self-host
# setup, but files won't survive a redeploy on most PaaS hosts). Cloudflare R2's free
# tier (10GB storage, no egress fees) is a good lowest-cost production option --
# S3_ENDPOINT_URL looks like https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_URL=

# --- Razorpay (domestic/INR payments) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=          # set after creating the webhook in the Razorpay dashboard

# --- Outbound email (human handoff + booking notifications) ---
# Works with any SMTP provider. Free tiers: Resend (3k/mo), Brevo (300/day).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Employee
SMTP_USE_TLS=true

# --- Rate limiting ---
# Leave blank for in-memory limiting (fine for a single backend instance). Set this
# if you run more than one backend replica so all instances share rate-limit counters.
REDIS_URL=

# --- Google OAuth ("Continue with Google") ---
# Optional -- requires an OAuth client from Google Cloud Console, see DEPLOYMENT.md.
# Leave blank to simply not offer Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Scheduled jobs (weekly re-crawl + staleness nudges) ---
# Set to false on all but one replica if running multiple backend instances.
ENABLE_SCHEDULER=true

# --- Misc ---
APP_NAME=ai-employee
FRONTEND_URL=http://localhost:3000
